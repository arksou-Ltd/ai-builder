# AI Builder API 环境变量配置
# 基于 arksou-kernel-framework v0.3.9 配置规范
#
# 标注说明:
#   [必填] — 启动前必须填写，无合理默认值
#   [可选] — 有合理默认值，MVP 阶段通常无需修改（注释形式保留）

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=ai-builder
APP_ENV=development
DEBUG=true
# [可选] 应用版本号
APP_VERSION=0.1.0
# [可选] API 路由前缀
API_PREFIX=/api/v1

# =============================================================================
# 数据库配置（框架 RDBMS 模块，环境变量前缀: DB_）
# =============================================================================
# [可选] 已通过 create_db_deps 指定 PostgreSQL，无需配置
DB_DIALECT=postgresql
DB_DRIVER=postgresql+asyncpg
# [可选] 有代码默认值 localhost，如需自定义取消注释
DB_HOST=aws-1-us-east-1.pooler.supabase.com
# [可选] 默认 5432
DB_PORT=5432
# [可选] 默认 root，PostgreSQL 通常为 postgres
DB_USERNAME=postgres.whnhncglsrmymaycpujl
# [必填] 数据库密码
DB_PASSWORD=Woyaojiayou1$
# [必填] 数据库名
DB_DATABASE=ai_builder
# [可选] 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# [可选] 是否打印 SQL，开发调试用
# DB_ECHO=false

# =============================================================================
# Redis 配置
# =============================================================================
# [必填] Redis 主机地址
REDIS_HOST=34.194.77.181
# [可选] Redis 端口，默认 6379
REDIS_PORT=6379
# [可选] Redis 数据库编号，默认 0
REDIS_DB=2
# [必填] Redis 密码
REDIS_PASSWORD=Woyaojiayou1$
# [可选] 是否启用 SSL，默认 false
REDIS_SSL=false
# [可选] Redis 键前缀项目名（空则使用 APP_NAME）
REDIS_PROJECT_NAME=ai_builder
# [可选] Redis 键前缀模块名，默认 "api"
REDIS_MODULE_NAME=app_api

# =============================================================================
# Clerk 认证配置（环境变量前缀: CLERK_）
# =============================================================================
# [必填] JWKS 端点，格式: https://<domain>/.well-known/jwks.json
CLERK_JWKS_URL=https://intent-asp-72.clerk.accounts.dev/.well-known/jwks.json
# [必填] JWT Issuer URL，格式: https://<domain>
CLERK_JWT_ISSUER=https://intent-asp-72.clerk.accounts.dev
# [可选] JWT 受众，为空时跳过 aud 校验
# CLERK_JWT_AUDIENCE=
# [必填] Webhook 签名密钥，从 Clerk Dashboard → Webhooks 获取
CLERK_WEBHOOK_SECRET=whsec_3cqrcfTtBy40RxCIkMLwG3TSGz8nw9Mt
# [可选] Clerk 可发布密钥（前端/管理用途）
CLERK_PUBLISHABLE_KEY=pk_test_aW50ZW50LWFzcC03Mi5jbGVyay5hY2NvdW50cy5kZXYk
# [可选] Clerk 服务端密钥（Backend API 调用）
CLERK_SECRET_KEY=sk_test_p1aZ5Gl8rSzu3tUOLP1DqQsJfEiJxwV14QRNrgCiJC

# =============================================================================
# CORS 配置
# =============================================================================
# [可选] 允许的来源列表
CORS_ORIGINS=["http://localhost:3001"]
# [可选] 是否允许携带凭证，默认 true
# CORS_ALLOW_CREDENTIALS=true
# [可选] 允许的 HTTP 方法，默认 ["*"]
# CORS_ALLOW_METHODS=["*"]
# [可选] 允许的请求头，默认 ["*"]
# CORS_ALLOW_HEADERS=["*"]

# =============================================================================
# 日志配置
# =============================================================================
# [可选] 日志级别，默认 INFO
LOG_LEVEL=DEBUG
