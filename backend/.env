# AI Builder API 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=ai-native
APP_ENV=development
DEBUG=true

# 数据库配置
# host/port/user/name 有代码默认值（localhost:5432/postgres/ai_builder），如需自定义取消注释
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_NAME=ai_builder

# 数据库密码（必填）
DATABASE_PASSWORD=

# Redis 配置（本地默认 localhost:6379/0，如需自定义取消注释）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Clerk 认证配置（环境变量前缀: CLERK_）
# JWKS 端点（必填），格式: https://<domain>/.well-known/jwks.json
CLERK_JWKS_URL=
# JWT Issuer URL（必填），格式: https://<domain>
CLERK_JWT_ISSUER=
# Webhook 签名密钥（必填），从 Clerk Dashboard → Webhooks 获取
CLERK_WEBHOOK_SECRET=

# CORS 配置
CORS_ORIGINS=["http://localhost:3000"]

# 日志配置
LOG_LEVEL=DEBUG
