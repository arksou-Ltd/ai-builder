# AI Builder API 环境变量配置模板
# 基于 arksou-kernel-framework v0.3.9 配置规范
#
# 使用方法: 复制为 .env 并填写 [必填] 项
#   cp .env.example .env
#
# 标注说明:
#   [必填] — 启动前必须填写，无合理默认值
#   [可选] — 有合理默认值，MVP 阶段通常无需修改（注释形式保留）

# =============================================================================
# 应用基础配置
# =============================================================================
APP_NAME=ai-builder
APP_ENV=development
DEBUG=true
# [可选] 应用版本号
# APP_VERSION=0.1.0
# [可选] API 路由前缀
# API_PREFIX=/api/v1

# =============================================================================
# 数据库配置
# =============================================================================
# host/port/user/name 有代码默认值（localhost:5432/postgres/ai_builder），如需自定义取消注释
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_NAME=ai_builder
# [必填] 数据库密码
DATABASE_PASSWORD=

# =============================================================================
# Redis 配置
# =============================================================================
# [必填] Redis 主机地址
REDIS_HOST=
# [可选] Redis 端口，默认 6379
REDIS_PORT=6379
# [可选] Redis 数据库编号，默认 0
REDIS_DB=0
# [必填] Redis 密码
REDIS_PASSWORD=
# [可选] 是否启用 SSL，默认 false
REDIS_SSL=false
# [可选] Redis 键前缀项目名（空则使用 APP_NAME）
# REDIS_PROJECT_NAME=
# [可选] Redis 键前缀模块名，默认 "api"
# REDIS_MODULE_NAME=api

# =============================================================================
# Clerk 认证配置（环境变量前缀: CLERK_）
# =============================================================================
# [必填] JWKS 端点，格式: https://<domain>/.well-known/jwks.json
CLERK_JWKS_URL=
# [必填] JWT Issuer URL，格式: https://<domain>
CLERK_JWT_ISSUER=
# [可选] JWT 受众，为空时跳过 aud 校验
# CLERK_JWT_AUDIENCE=
# [必填] Webhook 签名密钥，从 Clerk Dashboard → Webhooks 获取
CLERK_WEBHOOK_SECRET=
# [可选] Clerk 可发布密钥（前端/管理用途）
# CLERK_PUBLISHABLE_KEY=
# [可选] Clerk 服务端密钥（Backend API 调用）
# CLERK_SECRET_KEY=

# =============================================================================
# CORS 配置
# =============================================================================
# [可选] 允许的来源列表
CORS_ORIGINS=["http://localhost:3001"]
# [可选] 是否允许携带凭证，默认 true
# CORS_ALLOW_CREDENTIALS=true
# [可选] 允许的 HTTP 方法，默认 ["*"]
# CORS_ALLOW_METHODS=["*"]
# [可选] 允许的请求头，默认 ["*"]
# CORS_ALLOW_HEADERS=["*"]

# =============================================================================
# 日志配置
# =============================================================================
# [可选] 日志级别，默认 INFO
LOG_LEVEL=DEBUG
